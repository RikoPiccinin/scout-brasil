<!DOCTYPE html>
<html>

<head>

    <title>Cadastrar Jogador</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


    <style>
        body {
            background: #f5f6fa;
        }

        .sidebar {
            height: 100vh;
            background: #0d6efd;
            color: white;
            position: fixed;
            width: 230px;
            padding: 20px;
        }

        .sidebar a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 10px;
            border-radius: 5px;
            margin-bottom: 5px;
        }

        .sidebar a:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        .content {
            margin-left: 250px;
            padding: 30px;
        }

        .card {
            border: none;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
        }
    </style>


</head>

<body>

    <!-- MENU -->
    <div class="sidebar">

        <h3>SCOUT BRASIL</h3>
        <br>

        <a href="/admin">Dashboard</a>
        <a href="/cadastro">Cadastrar Jogador</a>
        <a href="/ranking">Ranking</a>

    </div>

    <!-- CONTEÚDO -->

    <div class="content">

        <a href="/admin" class="btn btn-secondary mb-3">Voltar</a>

        <div class="card">

            <div class="card-body">

                <h3 class="mb-4">Cadastrar Jogador</h3>

                <form action="/enviar" method="POST" enctype="multipart/form-data">

                    <div class="row">

                        <div class="col-md-6">

                            <label>Nome</label>
                            <input name="nome" class="form-control">


                        </div>

                        <div class="col-md-3">

                            <label>Idade</label>
                            <input name="idade" type="number" class="form-control">

                        </div>

                        <div class="mb-3">

                            <label class="form-label">Time</label>

                            <input type="text" name="time" class="form-control" placeholder="Ex: Palmeiras">

                        </div>



                        <div class="col-md-3">

                            <label>Posição</label>
                            <select name="posicao" class="form-select">

                                <option>Atacante</option>
                                <option>Meia</option>
                                <option>Volante</option>
                                <option>Zagueiro</option>
                                <option>Lateral</option>
                                <option>Goleiro</option>

                            </select>

                        </div>
                        <div class="col-md-3">
                            <label>Foto do Jogador</label>
                            <input type="file" name="foto" class="form-control">
                        </div>

                    </div>

                    <hr>

                    <h5>Habilidades</h5>

                    <div class="row">

                        <div class="col-md-4">
                            <label>Velocidade</label>
                            <input name="velocidade" type="number" class="form-control" min="0" max="10">
                        </div>

                        <div class="col-md-4">
                            <label>Passe</label>
                            <input name="passe" type="number" class="form-control" min="0" max="10">
                        </div>

                        <div class="col-md-4">
                            <label>Finalização</label>
                            <input name="finalizacao" type="number" class="form-control" min="0" max="10">
                        </div>

                        <div class="col-md-4">
                            <label>Drible</label>
                            <input name="drible" type="number" class="form-control" min="0" max="10">
                        </div>

                        <div class="col-md-4">
                            <label>Defesa</label>
                            <input name="defesa" type="number" class="form-control" min="0" max="10">
                        </div>

                        <div class="col-md-4">
                            <label>Físico</label>
                            <input name="fisico" type="number" class="form-control" min="0" max="10">
                        </div>

                    </div>

                    <br>

                    <button class="btn btn-primary">Cadastrar</button>

                </form>

            </div>

        </div>

    </div>

</body>

</html>