<!DOCTYPE html>
<html>

<head>
<title>Editar Jogador</title>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f5f6fa;
}

.sidebar{
height:100vh;
background:#0d6efd;
color:white;
position:fixed;
width:230px;
padding:20px;
}

.sidebar a{
display:block;
color:white;
text-decoration:none;
padding:10px;
border-radius:5px;
margin-bottom:5px;
}

.sidebar a:hover{
background:rgba(255,255,255,0.2);
}

.content{
margin-left:250px;
padding:30px;
}

.card{
border:none;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

</style>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</head>

<body>

<!-- MENU -->
<div class="sidebar">

<h3>SCOUT BRASIL</h3>

<br>

<a href="/admin">Dashboard</a>
<a href="/cadastro">Cadastrar Jogador</a>
<a href="/ranking">Ranking</a>

</div>

<div class="content">
    
<a href="/admin" class="btn btn-secondary mb-3">Voltar</a>

<h2 class="mb-4">Editar Jogador</h2>

<div class="card">

<div class="card-body">

<form action="/editar/<%= jogador._id %>" method="POST" enctype="multipart/form-data">

<div class="row">

<div class="col-md-6 mb-3">

<label class="form-label">Nome</label>

<input type="text"
name="nome"
class="form-control"
value="<%= jogador.nome %>">

</div>

<div class="col-md-3 mb-3">

<label class="form-label">Idade</label>

<input type="number"
name="idade"
class="form-control"
value="<%= jogador.idade %>">

</div>
<div class="col-md-4 mb-3">

<label class="form-label">Time</label>
<input type="text" 
name="time" 
class="form-control" 
value="<%= jogador.time %>">

</div>

<div class="col-md-3 mb-3">

<label class="form-label">Posição</label>

<select name="posicao" class="form-select">

<option <%= jogador.posicao=="Goleiro"?"selected":"" %>>Goleiro</option>
<option <%= jogador.posicao=="Zagueiro"?"selected":"" %>>Zagueiro</option>
<option <%= jogador.posicao=="Lateral"?"selected":"" %>>Lateral</option>
<option <%= jogador.posicao=="Volante"?"selected":"" %>>Volante</option>
<option <%= jogador.posicao=="Meia"?"selected":"" %>>Meia</option>
<option <%= jogador.posicao=="Atacante"?"selected":"" %>>Atacante</option>


</select>

</div>

</div>

<div class="row mb-4">

<div class="col-md-4 text-center">

<label class="form-label">Foto Atual</label>

<br>

<% if(jogador.foto){ %>

<img src="/uploads/<%= jogador.foto %>"
class="img-fluid rounded mb-3"
width="150">

<% } else { %>

<p>Sem foto cadastrada</p>

<% } %>

</div>

<div class="col-md-8">

<label class="form-label">Alterar Foto</label>

<input type="file" name="foto" class="form-control">

</div>

</div>

<hr>

<h4>Habilidades</h4>

<div class="row">

<div class="col-md-2 mb-3">
<label>Velocidade</label>
<input type="number" name="velocidade" class="form-control" value="<%= jogador.velocidade %>">
</div>

<div class="col-md-2 mb-3">
<label>Passe</label>
<input type="number" name="passe" class="form-control" value="<%= jogador.passe %>">
</div>

<div class="col-md-2 mb-3">
<label>Finalização</label>
<input type="number" name="finalizacao" class="form-control" value="<%= jogador.finalizacao %>">
</div>

<div class="col-md-2 mb-3">
<label>Drible</label>
<input type="number" name="drible" class="form-control" value="<%= jogador.drible %>">
</div>

<div class="col-md-2 mb-3">
<label>Defesa</label>
<input type="number" name="defesa" class="form-control" value="<%= jogador.defesa %>">
</div>

<div class="col-md-2 mb-3">
<label>Físico</label>
<input type="number" name="fisico" class="form-control" value="<%= jogador.fisico %>">
</div>

</div>

<button class="btn btn-primary">Salvar Alterações</button>

</form>

</div>

</div>

</div>