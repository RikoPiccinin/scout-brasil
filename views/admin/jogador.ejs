<!DOCTYPE html>
<html>

<head>

<title>Perfil do Jogador</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
background:#f5f6fa;
}

.sidebar{
height:100vh;
background:#0d6efd;
color:white;
position:fixed;
width:230px;
padding:20px;
}

.sidebar a{
display:block;
color:white;
text-decoration:none;
padding:10px;
border-radius:5px;
margin-bottom:5px;
}

.sidebar a:hover{
background:rgba(255,255,255,0.2);
}

.content{
margin-left:250px;
padding:30px;
}

.card{
border:none;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<!-- MENU LATERAL -->

<div class="sidebar">

<h3>SCOUT BRASIL</h3>

<br>

<a href="/admin">Dashboard</a>
<a href="/cadastro">Cadastrar Jogador</a>
<a href="/ranking">Ranking</a>

</div>

<!-- CONTEÚDO -->

<div class="content">

<a href="/admin" class="btn btn-secondary mb-3">Voltar</a>

<div class="card">

<div class="card-body">

<div class="row">

<!-- FOTO -->

<div class="col-md-4 text-center">

<% if(jogador.foto){ %>
    

<img src="/uploads/<%= jogador.foto %>" 
class="img-fluid rounded mb-3"
width="200">

<% } else { %>

<p>Sem foto cadastrada</p>

<% } %>

</div>

<!-- INFO -->

<div class="col-md-8">

<h2><%= jogador.nome %></h2>

<p><strong>Idade:</strong> <%= jogador.idade %></p>

<p><strong>Posição:</strong> <%= jogador.posicao %></p>

<p><strong>Time:</strong> <%= jogador.time %></p>

</div>

</div>

</div>

</div>

<!-- HABILIDADES -->

<div class="card mt-4">

<div class="card-body">

<h4>Habilidades</h4>

<canvas id="radar"></canvas>

</div>

</div>

</div>

<script>

const ctx = document.getElementById('radar');

new Chart(ctx, {

type: 'radar',

data: {

labels: [

'Velocidade',
'Passe',
'Finalização',
'Drible',
'Defesa',
'Físico'

],

datasets: [{

label: '<%= jogador.nome %>',

data: [

<%= jogador.velocidade %>,
<%= jogador.passe %>,
<%= jogador.finalizacao %>,
<%= jogador.drible %>,
<%= jogador.defesa %>,
<%= jogador.fisico %>

]

}]

},

options: {

scales: {

r: {

min: 0,
max: 10

}

}

}

});

</script>

</body>

</html>