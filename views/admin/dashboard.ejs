

<!DOCTYPE html>
<html>

<head>

<title>SCOUT BRASIL - Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
background:#f5f6fa;
}

.sidebar{
height:100vh;
background:#0d6efd;
color:white;
position:fixed;
width:230px;
padding:20px;
}

.sidebar h3{
margin-bottom:30px;
}

.sidebar a{
display:block;
color:white;
text-decoration:none;
padding:10px;
border-radius:5px;
margin-bottom:5px;
}

.sidebar a:hover{
background:rgba(255,255,255,0.2);
}

.content{
margin-left:250px;
padding:30px;
}

.card{
border:none;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<!-- MENU LATERAL -->

<div class="sidebar">

<h3>SCOUT BRASIL</h3>

<a href="/admin">Dashboard</a>

<a href="/cadastro">Cadastrar Jogador</a>

<a href="/ranking">Ranking</a>

<a href="/logout">Sair</a>

</div>

<!-- CONTEÚDO -->

<div class="content">

<h2 class="mb-4">Dashboard</h2>

<div class="row">

<div class="col-md-3">

<div class="card text-center">

<div class="card-body">

<h6>Total Jogadores</h6>

<h2><%= total %></h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card text-center">

<div class="card-body">

<h6>Média Velocidade</h6>

<h2><%= mediaVel %></h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card text-center">

<div class="card-body">

<h6>Média Passe</h6>

<h2><%= mediaPas %></h2>

</div>

</div>

</div>

<div class="col-md-3">

<div class="card text-center">

<div class="card-body">

<h6>Média Finalização</h6>

<h2><%= mediaFin %></h2>

</div>

</div>

</div>

</div>

<!-- TABELA -->

<div class="card mt-4">

<div class="card-body">

    <form action="/admin" method="GET" class="mb-3">

<div class="input-group">

<input 
type="text" 
name="busca" 
class="form-control"
placeholder="Buscar jogador">

<button class="btn btn-primary">
Pesquisar
</button>

<a href="/admin" class="btn btn-secondary">
Limpar
</a>

</div>

</form>

<h5>Jogadores Cadastrados</h5>

<table class="table table-striped">

<tr>

<th>Nome</th>
<th>Idade</th>
<th>Posição</th>
<th>Ações</th>

</tr>

<% jogadores.forEach(j => { %>

<tr>

<td><%= j.nome %></td>
<td><%= j.idade %></td>
<td><%= j.posicao %></td>

<td>

<a href="/jogador/<%= j._id %>" class="btn btn-info btn-sm">Perfil</a>

<a href="/editar/<%= j._id %>" class="btn btn-warning btn-sm">Editar</a>

<form action="/excluir/<%= j._id %>" onclick="return confirm('Deseja excluir este jogador?')" method="POST" style="display:inline;">

<button class="btn btn-danger btn-sm">Excluir</button>

</form>

</td>

</tr>

<% }) %>

</table>

</div>

</div>

</div>

</body>

</html>