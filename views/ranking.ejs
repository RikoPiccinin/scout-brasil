<!DOCTYPE html>
<html>

<head>

<title>Ranking de Jogadores</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
<style>

body{
background:#f5f6fa;
}

.sidebar{
height:100vh;
background:#0d6efd;
color:white;
position:fixed;
width:230px;
padding:20px;
}

.sidebar a{
display:block;
color:white;
text-decoration:none;
padding:10px;
border-radius:5px;
margin-bottom:5px;
}

.sidebar a:hover{
background:rgba(255,255,255,0.2);
}

.content{
margin-left:250px;
padding:30px;
}

.card{
border:none;
box-shadow:0 5px 15px rgba(0,0,0,0.1);
}

</style>
</head>

<body>

<div class="sidebar">

<h3>SCOUT BRASIL</h3>

<br>

<a href="/admin">Dashboard</a>
<a href="/cadastro">Cadastrar Jogador</a>
<a href="/ranking">Ranking</a>

</div>

<div class="content">

    <a href="/admin" class="btn btn-secondary mb-3">Voltar</a>

<h2>Ranking de Jogadores</h2>
<br>

<div class="card">

<div class="card-body">

<table class="table table-striped">

<tr>

<th>#</th>
<th>Nome</th>
<th>Posição</th>
<th>Score</th>

</tr>

<% jogadores.forEach((j,i)=>{ %>

<tr>

<td><%= i+1 %></td>
<td><%= j.nome %></td>
<td><%= j.posicao %></td>
<td><%= j.score.toFixed(1) %></td>

</tr>

<% }) %>

</table>

</div>

</div>

</div>

</body>

</html>